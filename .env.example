# 이 파일은 로컬 실행용 환경 변수입니다.
# 실제 키/비밀번호는 절대 Git에 커밋하지 않습니다.

# -----------------------------------------------------------------------------
# 기본 실행 환경
# - APP_ENV는 local, staging, production 같은 실행 환경을 구분합니다.
# - LOG_LEVEL은 로컬 DEBUG, 운영 INFO/WARNING 이상을 권장합니다.
# -----------------------------------------------------------------------------
APP_ENV=local
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# 데이터 저장소
# - DATABASE_URL은 애플리케이션이 직접 사용하는 SQLAlchemy 접속 문자열입니다.
# - REDIS_URL은 refresh token 저장소와 캐시/큐 확장에 사용합니다.
# -----------------------------------------------------------------------------
DATABASE_URL=mysql+pymysql://my_life_movie:my_life_movie_password@localhost:3307/my_life_movie
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# 인증 토큰
# - REFRESH_TOKEN_STORE는 database 또는 redis를 사용합니다.
# - Redis 저장소 사용 시 retention 값은 회전/폐기 토큰의 재사용 탐지 보존 기간입니다.
# -----------------------------------------------------------------------------
REFRESH_TOKEN_STORE=redis
REFRESH_TOKEN_REDIS_RETENTION_SECONDS=86400

# -----------------------------------------------------------------------------
# 외부 AI 및 음악 API
# - OPENAI_API_KEY는 이야기 구조화와 영상 생성 provider에서 사용합니다.
# - Spotify 키는 음악 추천에 사용하며, preview가 없으면 보강 provider를 사용할 수 있습니다.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TIMEOUT_SECONDS=10
OPENAI_CHAT_MAX_TOKENS=250
OPENAI_STORY_FINALIZE_TIMEOUT_SECONDS=45
OPENAI_STORY_FINALIZE_MAX_TOKENS=900
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 영상 생성 provider
# - VIDEO_GENERATION_PROVIDER는 mock, openai, fal 중 하나를 사용합니다.
# - 로컬 실제 생성 테스트는 openai를 기준으로 검증합니다.
# -----------------------------------------------------------------------------
VIDEO_GENERATION_PROVIDER=auto
GENERATED_MEDIA_DIR=generated

# -----------------------------------------------------------------------------
# 로컬/S3 미디어 저장소
# - STORAGE_PROVIDER가 local이면 LOCAL_* 설정을 사용합니다.
# - STORAGE_PROVIDER가 s3이면 AWS/S3 설정과 presigned URL 설정을 사용합니다.
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=generated
LOCAL_PUBLIC_BASE_URL=/generated
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=
S3_ENDPOINT_URL=
S3_GENERATED_VIDEO_PREFIX=generated/videos
S3_GENERATED_THUMBNAIL_PREFIX=generated/thumbnails
S3_MUSIC_PREFIX=music
S3_PRESIGNED_URL_EXPIRE_SECONDS=900

# -----------------------------------------------------------------------------
# OpenAI 영상 생성
# - SECONDS는 현재 단일 생성 클립 길이입니다. 장편 영상은 scene job 구조가 별도로 필요합니다.
# - POLL_INTERVAL은 provider 상태 조회 간격, MAX_WAIT은 최대 대기 시간입니다.
# -----------------------------------------------------------------------------
OPENAI_VIDEO_MODEL=sora-2
OPENAI_VIDEO_SIZE=1280x720
OPENAI_VIDEO_SECONDS=8
OPENAI_VIDEO_POLL_INTERVAL_SECONDS=5
OPENAI_VIDEO_MAX_WAIT_SECONDS=900

# -----------------------------------------------------------------------------
# fal 영상 생성
# - fal provider를 사용할 때만 필요합니다.
# - FAL_KEY는 절대 커밋하지 않습니다.
# -----------------------------------------------------------------------------
FAL_KEY=
FAL_MODEL_ID=fal-ai/wan-alpha
FAL_QUEUE_BASE_URL=https://queue.fal.run
FAL_POLL_INTERVAL_SECONDS=5
FAL_MAX_WAIT_SECONDS=900

# -----------------------------------------------------------------------------
# 영상 생성 worker (Redis Streams 큐)
# - 큐는 Redis Stream + consumer group으로 동작합니다. (REDIS_URL 필요)
# - BLOCK_MS: XREADGROUP 대기(ms). RECLAIM_MIN_IDLE_MS: 죽은 워커 entry 회수 기준(ms).
#   회수 기준은 provider 최대 실행시간(약 900s)보다 길어야 살아있는 긴 job을 안 건드립니다.
# - POLL_INTERVAL_SECONDS는 레거시 설정으로 더 이상 큐 폴링에 쓰이지 않습니다.
# -----------------------------------------------------------------------------
VIDEO_GENERATION_WORKER_POLL_INTERVAL_SECONDS=5
VIDEO_GENERATION_STREAM_KEY=video_generation:stream
VIDEO_GENERATION_CONSUMER_GROUP=workers
VIDEO_GENERATION_BLOCK_MS=5000
VIDEO_GENERATION_RECLAIM_MIN_IDLE_MS=1200000
VIDEO_GENERATION_RECLAIM_COUNT=10

# -----------------------------------------------------------------------------
# Docker Compose 로컬 MySQL/Redis
# - docker-compose.yml의 MySQL, Redis 컨테이너 초기화와 포트 매핑에 사용합니다.
# - DATABASE_URL/REDIS_URL과 포트 값이 서로 맞아야 합니다.
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=my_life_movie
MYSQL_USER=my_life_movie
MYSQL_PASSWORD=my_life_movie_password
MYSQL_PORT=3307
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# TMDB 영화 추천
# - TMDB_ACCESS_TOKEN은 유사 영화 추천과 포스터/상세 링크 조회에 사용합니다.
# - TMDB 데이터/이미지를 화면에 표시할 때는 출처 표기가 필요합니다.
# -----------------------------------------------------------------------------
TMDB_ACCESS_TOKEN=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_POSTER_SIZE=w500
TMDB_LANGUAGE=ko-KR
TMDB_TIMEOUT_SECONDS=5
